{
  "name": "opencode-dreams",
  "version": "0.1.0",
  "description": "OpenCode plugin: two-stage reflection & memory consolidation pipeline with support for opencode-mem, true-mem, simple-memory, and opencode-lcm.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "oc-plugin": [
    "server"
  ],
  "files": [
    "dist",
    "src",
    "docs",
    "examples",
    "integrations",
    "readme.md",
    "INTEGRATIONS.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opendream",
    "memory",
    "memory-consolidation",
    "reflection",
    "ai-agent",
    "github-copilot",
    "typescript",
    "opencode-mem",
    "true-mem",
    "opencode-lcm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryurexflipper/Opencode-Dreams.git"
  },
  "bugs": {
    "url": "https://github.com/ryurexflipper/Opencode-Dreams/issues"
  },
  "homepage": "https://github.com/ryurexflipper/Opencode-Dreams#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.41",
    "@opencode-ai/sdk": "^1.14.41"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.41",
    "@opencode-ai/sdk": "^1.14.41",
    "@types/node": "^22.15.21",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
